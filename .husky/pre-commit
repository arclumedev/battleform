#!/bin/sh

# Ensure cargo is available (rustup installs to ~/.cargo/bin)
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# Run lint-staged for backend and frontend (only if relevant files changed)
npx lint-staged

# Check if game crate files changed — if so, run cargo clippy
GAME_CHANGED=$(git diff --cached --name-only -- game/ client/)
if [ -n "$GAME_CHANGED" ]; then
  if [ -d "game" ]; then
    echo "game/ changed — running cargo clippy..."
    (cd game && cargo clippy --all-targets -- -D warnings)
  elif [ -d "client" ]; then
    echo "client/ changed — running cargo clippy..."
    (cd client && cargo clippy --all-targets -- -D warnings)
  fi
fi
