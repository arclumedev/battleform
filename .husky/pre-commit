#!/bin/sh

# Ensure cargo is available (rustup installs to ~/.cargo/bin)
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# Run lint-staged for backend and frontend (only if relevant files changed)
npx lint-staged

# Check if game client files changed — if so, run cargo clippy
CLIENT_CHANGED=$(git diff --cached --name-only -- client/)
if [ -n "$CLIENT_CHANGED" ]; then
  echo "client/ changed — running cargo clippy..."
  (cd client && cargo clippy --all-targets -- -D warnings)
fi
