{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: AdonisJS",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/multiplayer_server",
      "runtimeVersion": "25",
      "runtimeExecutable": "node",
      "runtimeArgs": ["ace", "serve", "--hmr"],
      "envFile": "${workspaceFolder}/multiplayer_server/.env",
      "skipFiles": ["<node_internals>/**"],
      "console": "internalConsole",
      "env": {
        "NODE_ENV": "development"
      }
    },
    {
      "name": "Backend: AdonisJS (Attach)",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true
    },
    {
      "name": "Backend: Migrations",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/multiplayer_server",
      "runtimeVersion": "25",
      "runtimeExecutable": "node",
      "runtimeArgs": ["ace", "migration:run"],
      "skipFiles": ["<node_internals>/**"],
      "console": "internalConsole"
    },
    {
      "name": "Backend: Seeds",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/multiplayer_server",
      "runtimeVersion": "25",
      "runtimeExecutable": "node",
      "runtimeArgs": ["ace", "db:seed"],
      "skipFiles": ["<node_internals>/**"],
      "console": "internalConsole"
    },
    {
      "name": "Backend: Tests",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/multiplayer_server",
      "runtimeVersion": "25",
      "runtimeExecutable": "node",
      "runtimeArgs": ["ace", "test"],
      "skipFiles": ["<node_internals>/**"],
      "console": "internalConsole"
    },
    {
      "name": "Game: Native (Debug)",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": ["build", "--manifest-path", "${workspaceFolder}/game/Cargo.toml", "-p", "bf_game", "--no-default-features", "--features", "native", "--bin", "battleform"],
        "filter": {
          "name": "battleform",
          "kind": "bin"
        }
      },
      "cwd": "${workspaceFolder}/game",
      "env": {
        "RUST_LOG": "info"
      },
      "console": "internalConsole"
    },
    {
      "name": "Game: Native (Hot Reload)",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": ["build", "--manifest-path", "${workspaceFolder}/game/Cargo.toml", "-p", "bf_game", "--no-default-features", "--features", "hot", "--bin", "battleform"],
        "filter": {
          "name": "battleform",
          "kind": "bin"
        }
      },
      "cwd": "${workspaceFolder}/game",
      "env": {
        "RUST_LOG": "info"
      },
      "console": "internalConsole"
    },
    {
      "name": "Game: Native (Release)",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": ["build", "--manifest-path", "${workspaceFolder}/game/Cargo.toml", "-p", "bf_game", "--no-default-features", "--features", "native", "--bin", "battleform", "--release"],
        "filter": {
          "name": "battleform",
          "kind": "bin"
        }
      },
      "cwd": "${workspaceFolder}/game",
      "env": {
        "RUST_LOG": "info"
      },
      "console": "internalConsole"
    },
    {
      "name": "Frontend: Vite Dev",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "skipFiles": ["<node_internals>/**"],
      "console": "internalConsole"
    },
    {
      "name": "Frontend: Chrome Debug",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend/src",
      "sourceMapPathOverrides": {
        "webpack:///src/*": "${webRoot}/*"
      }
    }
  ],
  "compounds": [
    {
      "name": "Full Stack (Backend + Frontend)",
      "configurations": ["Backend: AdonisJS", "Frontend: Vite Dev"]
    },
    {
      "name": "Full Stack + Native Game",
      "configurations": ["Backend: AdonisJS", "Frontend: Vite Dev", "Game: Native (Debug)"]
    }
  ]
}
