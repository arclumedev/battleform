{
  "name": "battleform",
  "version": "1.0.0",
  "private": true,
  "description": "AI-vs-AI Real-Time Strategy Arena",
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "multiplayer_server/**/*.{ts,tsx}": [
      "bash -c 'cd multiplayer_server && npm run lint -- --no-error-on-unmatched-pattern'",
      "bash -c 'cd multiplayer_server && npm run typecheck'"
    ],
    "frontend/**/*.{ts,tsx,vue}": [
      "bash -c 'cd frontend && npm run lint -- --no-error-on-unmatched-pattern'",
      "bash -c 'cd frontend && npm run typecheck'"
    ]
  }
}
